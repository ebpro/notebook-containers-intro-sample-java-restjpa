<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_2.xsd"
             version="3.2">

    <persistence-unit name="restjpa-pu">

        <!-- Use Hibernate as JPA provider -->
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Explicitly list entity classes -->
        <class>fr.univtln.bruno.demos.docker.adapter.persistence.PersonEntity</class>

        <properties>
            <!-- JDBC connection (defaults can be overridden at runtime via env) -->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="${DB_URL}"/>
            <property name="jakarta.persistence.jdbc.user" value="${DB_USER}"/>
            <property name="jakarta.persistence.jdbc.password" value="${DB_PASSWORD}"/>

            <!-- Use standard JPA schema generation property; default to 'validate' -->

            <property name="jakarta.persistence.schema-generation.database.action" value="${DB_SCHEMA_ACTION}"/>

            <!-- SQL import script (executed when schema-generation creates the schema) -->
            <property name="jakarta.persistence.sql-load-script-source" value="data.sql"/>

            <!-- Hibernate-specific tuning (kept for runtime behavior) -->
            <!-- Let Hibernate auto-detect the dialect for the runtime environment -->
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="false"/>
            <property name="hibernate.jdbc.batch_size" value="20"/>
            <property name="hibernate.order_inserts" value="true"/>
            <property name="hibernate.order_updates" value="true"/>

            <!-- Validation -->
            <property name="hibernate.validator.apply_to_ddl" value="false"/>
            <property name="hibernate.validator.autoregister_listeners" value="false"/>
        </properties>
    </persistence-unit>

</persistence>
